PORT=4000
NODE_NO_WARNINGS=1
APP_USER=root
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcp_pm
REDIS_URL=redis://localhost:6379
POSTGRES_PASSWORD=postgres
FS_BASE_PATH=./workspace
STATIC_FRONTEND_DIR=

# Host ports used by Docker Compose. Change these if the VM already runs Postgres or Redis.
APP_BIND_HOST=127.0.0.1
APP_HOST_PORT=4000
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
REDIS_BIND_HOST=127.0.0.1
REDIS_HOST_PORT=6379

# Docker filesystem access.
# By default the app can read and write only inside ./workspace on the host.
# Set HOST_WORKSPACE_ROOT to another path if you want KiraAI to work on external projects.
# Keep APP_USER=root when using Docker Desktop with Windows drive mounts such as C:/.
# For production Linux-only deployments, use APP_USER=node.
HOST_WORKSPACE_ROOT=./workspace
CONTAINER_FS_ROOT=/workspace
FS_TREE_MAX_DIRS=80
FS_MAX_READ_BYTES=1048576

# Production security. Keep AUTH_ENABLED=false for local-only/dev.
# Generate AUTH_ADMIN_PASSWORD_HASH with:
#   node backend/src/hashPassword.js "your-long-admin-password"
AUTH_ENABLED=false
AUTH_BOOTSTRAP_EMAIL=
AUTH_ADMIN_PASSWORD_HASH=
SESSION_SECRET=
INVITE_TTL_MS=604800000
AUTH_SESSION_TTL_MS=43200000
AUTH_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=
TRUST_PROXY=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
AUTH_LOGIN_RATE_LIMIT_MAX=10
EXPENSIVE_RATE_LIMIT_MAX=30
CODE_JOB_MAX_ACTIVE=0
ML_JOB_MAX_ACTIVE=0

AI_PROVIDER=codex_cli
CONTAINER_AI_PROVIDER=codex_cli
AI_FALLBACK_PROVIDERS=openai,codex_cli,anthropic
AI_RETRY_COUNT=2
AI_RETRY_DELAY_MS=600

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CODE_AI_MODEL=gpt-5.5
CODE_JOB_SANDBOX=danger-full-access
CODE_JOB_REASONING_EFFORT=low
CODE_JOB_TIMEOUT_MS=900000
CODE_JOB_PREPARE_DEPS=true
CODE_JOB_PREPARE_DEPS_TIMEOUT_MS=180000
CODE_JOB_REQUIRE_LEARNED_SKILLS=true
IMAGE_GENERATION_ENABLED=true
IMAGE_PROVIDER=codex_cli
IMAGE_CODEX_MODEL=
IMAGE_CODEX_SANDBOX=workspace-write
IMAGE_CODEX_REASONING_EFFORT=low
IMAGE_CODEX_TIMEOUT_MS=900000
IMAGE_DEFAULT_SIZE=1024x1024
IMAGE_MAX_PER_JOB=1
JOB_RESUME_ENABLED=true
CODE_JOB_MAX_RESUME_ATTEMPTS=2
ML_JOB_MAX_RESUME_ATTEMPTS=2
JOB_RESUME_STALE_MS=30000

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

CODEX_BIN=codex
CONTAINER_CODEX_BIN=/app/node_modules/.bin/codex
# Optional: mount an existing Codex login directory into the app container.
CODEX_HOME_HOST=./.codex-host
CODEX_MODEL=
CODEX_SUMMARY_MODEL=gpt-5.3-codex
CODEX_SUMMARY_SANDBOX=danger-full-access
CODEX_TIMEOUT_MS=900000

ML_MIND_ENABLED=true
ML_AI_PROVIDER=codex_cli
ML_EMBEDDING_PROVIDER=local_hash
ML_EMBEDDING_MODEL=text-embedding-3-small
ML_SKILL_MODEL=gpt-5.5
ML_MAX_REPO_MB=120
ML_MAX_FILE_BYTES=200000
ML_CHUNK_SIZE=1800
ML_CHUNK_OVERLAP=250
ML_RETRIEVAL_LIMIT=8
ML_RUNTIME_SELECTOR=fast_cached
ML_SELECTOR_TIMEOUT_MS=2500
ML_MIND_CACHE_TTL_MS=86400000
ML_MIND_MAX_RUNTIME_SKILLS=3
ML_SCRAPER_MAX_PAGES=25
ML_SCRAPER_MAX_DEPTH=2
ML_SCRAPER_MAX_TOTAL_MB=30
ML_SCRAPER_TIMEOUT_MS=15000
ML_ALLOW_PRIVATE_NETWORK_FETCHES=false

VITE_API_URL=/api
VITE_DEFAULT_ROOT=/workspace
